{
  "name": "frontend",
  "private": true,
  "version": "3.0.0",
  "author": "Luis Vilela Acuña <contacto@edumind.es>",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "bash scripts/capture-previous-assets.sh",
    "build": "tsc -b && vite build",
    "postbuild": "bash scripts/create-asset-aliases.sh dist",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview",
    "mobile:preflight": "bash scripts/mobile/preflight.sh",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:ios:add": "npx cap add ios",
    "mobile:ios:sync": "npm run build && npx cap sync ios",
    "mobile:ios:sync:prod": "VITE_API_URL=https://liga.edumind.es/api/v1 npm run mobile:ios:sync",
    "mobile:ios:open": "npx cap open ios",
    "mobile:android:add": "npx cap add android",
    "mobile:android:sync": "npm run build && npx cap sync android",
    "mobile:android:sync:prod": "VITE_API_URL=https://liga.edumind.es/api/v1 npm run mobile:android:sync",
    "mobile:android:open": "npx cap open android"
  },
